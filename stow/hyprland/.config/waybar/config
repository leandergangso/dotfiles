{
  "layer": "top",
  "position": "bottom",
  "height": 28,
  "spacing": 6,
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["tray", "pulseaudio", "network", "cpu", "memory"],

  "clock": {
    "format": "{:%Y-%m-%d %H:%M}"
  },
  "cpu": {
    "format": "CPU {usage}%"
  },
  "memory": {
    "format": "RAM {used:0.1f}G"
  },
  "network": {
    "format-wifi": "WiFi {essid} {signalStrength}%",
    "format-ethernet": "LAN",
    "format-disconnected": "Offline"
  },
  "pulseaudio": {
    "format": "VOL {volume}%"
  }
}
